# ─── Cloudflare R2 (used by scripts/setup-gallery.mjs only) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=photosha-photos

# ─── CDN base URL ─────────────────────────────────────────────
# Default: https://images.photosha.ch
CDN_BASE_URL=https://images.photosha.ch

# ─── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@photosha.ch
SHA_EMAIL=sha@photosha.ch

# ─── Cloudflare Turnstile ─────────────────────────────────────
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── Umami analytics ─────────────────────────────────────────
# Set to your self-hosted Umami website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://umami.photosha.ch/script.js
